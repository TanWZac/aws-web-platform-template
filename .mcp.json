{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "type": "stdio"
    },
    "headroom": {
      "command": "python",
      "args": ["-m", "headroom.mcp"],
      "type": "stdio",
      "env": {
        "HEADROOM_COMPRESS_BASH": "1",
        "HEADROOM_COMPRESS_READ": "1"
      }
    }
  }
}
